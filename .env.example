# Voxtral Client Configuration Template
# Copy this file to .env and fill in your values

# 1. Server Connection
VOXTRAL_HOST=https://xxxx-yyyy-zzzz.ngrok-free.app
VOXTRAL_PORT=8000
VOXTRAL_CHUNK_INTERVAL=0.1
VOXTRAL_RESPONSE_TIMEOUT=30
NGROK_AUTHTOKEN=

# 2. Javis Engine Connection (Required for Javis)
# Option A: Account Credentials (Recommended - dynamically fetches token)
JAVIS_EMAIL=
JAVIS_PASSWORD=

# Option B: Manual Session ID and Token (Optional - overrides credentials)
JAVIS_SESSION_ID=
JAVIS_TOKEN=
JAVIS_WS_URL=wss://api2.javis-audio.developer.vi-jp-te.info/api/v4/ws/improved
JAVIS_LOGIN_URL=https://ai.javis-dev.vi-jp-te.info/api/v1/login/access-token

# 3. LLM API Configuration (Required for Hallucination Evaluation)
# OpenAI Format: sk-xxx
OPENAI_API_KEY=
# Custom Base URL for self-hosted API (e.g., LiteLLM)
# Note: Usually ends with /v1
OPENAI_BASE_URL=https://litellm-ai.prod.vi-jp-te.info/v1

# Groq Format: gsk_xxx
GROQ_API_KEY=

# Multi-key configuration (Optional: for batch processing speed)
# Format: key1,key2,key3
OPENAI_API_KEYS=
GROQ_API_KEYS=

# Preferred model for evaluation (e.g., javis/Qwen3-14B-AWQ or llama-3.3-70b-versatile)
EVALUATION_MODEL=javis/Qwen3-14B-AWQ

# 3. Hugging Face Token (Optional: for some model loaders)
# Generate one at: https://huggingface.co/settings/tokens
HF_TOKEN=
GITHUB_TOKEN=